# Environment Variables Template
# Copy this to .env.local for local development
# DO NOT commit .env files to Git!

# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary Configuration
# Get these from: https://cloudinary.com/console
# The upload preset must be UNSIGNED and have "raw" resource type enabled
# (Settings → Upload → Upload presets → Add preset → Signing mode: Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Optional: Analytics, error tracking, etc.
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# Feature flags
# Keep false in production until Open Campus is ready.
VITE_FEATURE_OPEN_CAMPUS=false

# AI Study Chat (agentrouter.org)
# Get your API key from agentrouter.org
VITE_AI_BASE_URL=https://your-agentrouter-base-url/v1
VITE_AI_API_KEY=your-agentrouter-api-key
VITE_AI_MODEL=claude-sonnet-4-5

# AI Voice — ElevenLabs (BEST quality, free 10k chars/month)
# Sign up at elevenlabs.io → Profile → API Key. Takes 2 minutes.
# When set, ElevenLabs is used first (overrides Groq/OpenAI TTS below).
# VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice IDs (copy from elevenlabs.io/voice-library):
#   Rachel (warm female): 21m00Tcm4TlvDq8ikWAM  ← default
#   Bella  (soft female): EXAVITQu4vr4xnSDxMaL
#   Antoni (natural male): ErXwobaYiN019PkySvjV
#   Josh   (deep male):    TxGEqnHWrfWFTfGW9XjX
# VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# AI Voice fallback (Text-to-Speech) — OpenAI-compatible /audio/speech endpoint
# FREE option: Use Groq (same key as VITE_AI_API_KEY above, playai-tts model)
VITE_TTS_BASE_URL=https://api.groq.com/openai/v1
VITE_TTS_API_KEY=your-groq-api-key
VITE_TTS_MODEL=playai-tts
# Groq/PlayAI voice options: Celeste-PlayAI | Fritz-PlayAI | Quinn-PlayAI | Liam-PlayAI
VITE_TTS_VOICE=Celeste-PlayAI
# PAID alternative (OpenAI — higher naturalness):
# VITE_TTS_BASE_URL=https://api.openai.com/v1
# VITE_TTS_API_KEY=your-openai-api-key
# VITE_TTS_MODEL=tts-1
# VITE_TTS_VOICE=nova
# Falls back to browser speech synthesis if the endpoint is unavailable
